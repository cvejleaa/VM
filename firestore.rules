// ---------------------------------------------------------------------------
// firestore.rules — Sikkerhedsregler for VM 2026 tippekonkurrence.
// Håndhæver principper fra docs/architecture.md:
//   - Spillere kan kun læse/skrive egne bets/bonusBets, og kun FØR deadline.
//   - points, role, status, result, facit kan aldrig skrives af spillere.
//   - Kun globalAdmin/owner skriver matches, result, facit.
//   - Globale admins kan godkende/afvise brugere; KUN owner ændrer roller.
// ---------------------------------------------------------------------------

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Hjælpefunktioner
    // -----------------------------------------------------------------------

    /** Er brugeren logget ind? */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Er brugeren godkendt (status == 'approved')? */
    function isApproved() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    /** Er brugeren owner? */
    function isOwner() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    /** Er brugeren global admin eller owner? (fuld daglig drift) */
    function isGlobalAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'globalAdmin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner'
      );
    }

    /** Er brugeren ejeren af dette dokument (ownerUid == uid)? */
    function isOwnerOfDoc(docData) {
      return isSignedIn() && request.auth.uid == docData.ownerUid;
    }

    /** Forsøger klienten at skrive til et beskyttet felt? (Function/registrerings-ejet) */
    function writingProtectedUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'approvedViaInvite', 'approvedAt',
                 'totalPoints', 'previousRank', 'groupPoints', 'knockoutPoints', 'bonusPoints',
                 'email', 'createdAt']);
    }

    /** Forsøger klienten at skrive til points-feltet? */
    function writingPointsField() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['points']);
    }

    // -----------------------------------------------------------------------
    // users/{uid}
    // -----------------------------------------------------------------------
    match /users/{uid} {
      // Godkendte brugere kan læse basisprofiler; alle kan altid læse sin egen
      // (så pending→approved kan opdatere live)
      allow read: if isApproved() || (isSignedIn() && request.auth.uid == uid);

      // Brugeren opretter selv sin profil ved registrering, men KUN med
      // role:'player', status:'pending' og NUL point (kan ikke selv blive
      // owner/approved eller starte med point på leaderboardet). E-mail må ikke
      // gemmes her — den bor i Firebase Authentication, så den ikke er læsbar
      // for andre spillere via users-dokumentet.
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == 'player'
        && request.resource.data.status == 'pending'
        && !request.resource.data.keys().hasAny(['email'])
        && request.resource.data.get('totalPoints', 0) == 0
        && request.resource.data.get('groupPoints', 0) == 0
        && request.resource.data.get('knockoutPoints', 0) == 0
        && request.resource.data.get('bonusPoints', 0) == 0;

      // Brugeren kan opdatere egne ikke-beskyttede felter (f.eks. displayName)
      allow update: if isSignedIn() && request.auth.uid == uid
        && !writingProtectedUserFields();

      // Global admin kan godkende/afvise brugere (status m.m.), men IKKE ændre
      // roller — kun ejeren udpeger/fjerner admins.
      allow update: if isGlobalAdmin()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);

      // Ejeren kan ændre alt, inkl. role (udpege/fjerne globale admins)
      allow update: if isOwner();

      // Ingen kan slette brugerprofiler (kun admin via Functions/console)
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // matches/{matchId}
    // -----------------------------------------------------------------------
    match /matches/{matchId} {
      // Godkendte brugere kan læse alle kampe
      allow read: if isApproved();

      // Kun globalAdmin/owner kan oprette og opdatere kampe
      allow create, update: if isGlobalAdmin();

      // Ingen sletter kampe fra klienten
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // bets/{betId}  (betId = uid_matchId)
    // -----------------------------------------------------------------------
    match /bets/{betId} {
      // Egne tips kan altid læses. Andres tips kan først læses EFTER kickoff
      // (så man ikke kan snyde før kampstart) — bruges til statistik og
      // dags-rangering. Admin kan altid læse.
      allow read: if isGlobalAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.uid)
        || (isApproved()
            && request.time >= get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.kickoff);

      // Opret bet: kun godkendt bruger, kun eget, points-felt må ikke sættes, og kun FØR kickoff
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.uid
        && !request.resource.data.keys().hasAny(['points'])
        && request.time < get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.kickoff;

      // Opdater bet: kun godkendt bruger, kun eget, points må ikke ændres, og kun FØR kickoff
      allow update: if isApproved()
        && request.auth.uid == resource.data.uid
        && !writingPointsField()
        && request.time < get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.kickoff;

      // Reaktioner: enhver godkendt bruger må ændre KUN 'reactions'-feltet, og
      // kun EFTER kickoff (hvor andres tips alligevel er synlige).
      allow update: if isApproved()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        && request.time >= get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.kickoff;

      // Ingen sletter bets fra klienten
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // bonusQuestions/{questionId}
    // -----------------------------------------------------------------------
    match /bonusQuestions/{questionId} {
      // Godkendte brugere kan læse bonusspørgsmål
      allow read: if isApproved();

      // Kun globalAdmin/owner kan oprette og opdatere (inkl. sætte facit)
      allow create, update: if isGlobalAdmin();
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // bonusBets/{bonusBetId}  (bonusBetId = uid_questionId)
    // -----------------------------------------------------------------------
    match /bonusBets/{bonusBetId} {
      // Egne bonus-svar kan altid læses. Admin kan altid læse alle (se hvem der
      // har svaret + godkende stavemåder). Andres svar kan først læses EFTER
      // spørgsmålet er låst (deadline passeret) — som med kamp-tips efter kickoff.
      allow read: if isGlobalAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.uid)
        || (isApproved()
            && request.time >= get(/databases/$(database)/documents/bonusQuestions/$(resource.data.questionId)).data.deadline);

      // Opret bonusbet: kun eget, points må ikke sættes, og kun FØR deadline
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.uid
        && !request.resource.data.keys().hasAny(['points'])
        && request.time < get(/databases/$(database)/documents/bonusQuestions/$(request.resource.data.questionId)).data.deadline;

      // Opdater bonusbet: kun eget, points må ikke ændres, og kun FØR deadline
      allow update: if isApproved()
        && request.auth.uid == resource.data.uid
        && !writingPointsField()
        && request.time < get(/databases/$(database)/documents/bonusQuestions/$(resource.data.questionId)).data.deadline;

      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // leagues/{leagueId}
    // -----------------------------------------------------------------------
    match /leagues/{leagueId} {
      // Godkendte brugere kan læse ligaer (nødvendigt for opslag via join-kode);
      // admin kan også læse alle.
      allow read: if isApproved() || isGlobalAdmin();

      // Opret liga: kun for sig selv, og altid som 'pending' (skal godkendes)
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.ownerUid
        && request.resource.data.memberUids.hasOnly([request.auth.uid])
        && request.resource.data.status == 'pending';

      // Liga-ejeren kan opdatere egne felter, men kan IKKE ændre status eller
      // tildele liga-admins (kun den globale ejer styrer adminUids).
      allow update: if isOwnerOfDoc(resource.data)
        && request.resource.data.status == resource.data.status
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminUids']);

      // Liga-admin (udpeget pr. liga) kan styre medlemmer og omdøbe ligaen
      // (samt liga-bonus, jf. leagueBonus-reglerne) — men IKKE scoring/format,
      // status, ejer eller adminUids.
      allow update: if isApproved()
        && (request.auth.uid in resource.data.get('adminUids', []))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'name']);

      // Tilmeld: godkendt bruger føjer KUN sit eget uid til en GODKENDT liga.
      // memberUids skal være præcis den gamle liste + kalderens uid (append-only),
      // så man hverken kan fjerne andre medlemmer eller tilføje fremmede uid'er.
      // (join-koden verificeres i klienten; koden er i forvejen læsbar for godkendte
      //  brugere, så den beskytter ikke mod tilmelding — append-only stopper griefing.)
      allow update: if isApproved()
        && resource.data.status == 'approved'
        && !(request.auth.uid in resource.data.memberUids)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
        && request.resource.data.memberUids == resource.data.memberUids.concat([request.auth.uid]);

      // globalAdmin/owner kan godkende/afvise og styre medlemmer — men kun den
      // GLOBALE ejer må ændre adminUids (tildele liga-admins).
      allow update: if isGlobalAdmin()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminUids']);

      // Den globale ejer kan alt, inkl. at tildele/fjerne liga-admins
      allow update: if isOwner();

      // Sletning: ejeren af ligaen eller en super-admin (owner)
      allow delete: if isOwner() || isOwnerOfDoc(resource.data);
    }

    // -----------------------------------------------------------------------
    // emailLog/{id} — log over udsendte mails. Skrives KUN af Cloud Functions
    // (admin SDK); globale admins kan læse den. Ingen klient-skrivning.
    // -----------------------------------------------------------------------
    match /emailLog/{id} {
      allow read: if isGlobalAdmin();
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // inviteAttempts/{uid} — rate-limit-tæller for indløsning af invitationskoder.
    // Skrives og læses KUN af Cloud Functions (admin SDK). Ingen klientadgang,
    // så brugere ikke kan nulstille deres egen forsøgstæller.
    // -----------------------------------------------------------------------
    match /inviteAttempts/{uid} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------------
    // leagueComments/{commentId} — beskeder på en ligas væg
    // -----------------------------------------------------------------------
    function isMemberOfLeague(leagueId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.memberUids;
    }

    match /leagueComments/{commentId} {
      // Kun medlemmer af ligaen kan læse væggen
      allow read: if isMemberOfLeague(resource.data.leagueId) || isGlobalAdmin();

      // Opret: kun som sig selv, kun hvis man er medlem af ligaen
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.uid
        && !request.resource.data.keys().hasAny(['edited'])
        && isMemberOfLeague(request.resource.data.leagueId);

      // Reaktioner: medlemmer må ændre KUN 'reactions'-feltet (ingen anden redigering)
      allow update: if isMemberOfLeague(resource.data.leagueId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

      // Slet: forfatteren selv, ligaens ejer eller en admin
      allow delete: if isGlobalAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.uid)
        || (isSignedIn() && request.auth.uid ==
            get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.ownerUid);
    }

    // -----------------------------------------------------------------------
    // messages/{messageId} — private 1:1-beskeder
    //   participants: [uidA, uidB] (sorteret), from, to, text, createdAt
    // -----------------------------------------------------------------------
    match /messages/{messageId} {
      // Kun de to deltagere kan læse beskeden
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;

      // Opret: afsenderen er sig selv, er deltager, og BEGGE deler den angivne
      // liga (man kan kun skrive med folk, man er i liga med).
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.from
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && request.resource.data.to in request.resource.data.participants
        && request.auth.uid in get(/databases/$(database)/documents/leagues/$(request.resource.data.leagueId)).data.memberUids
        && request.resource.data.to in get(/databases/$(database)/documents/leagues/$(request.resource.data.leagueId)).data.memberUids;

      // Beskeder kan ikke redigeres
      allow update: if false;

      // Slet: kun afsenderen
      allow delete: if isSignedIn() && request.auth.uid == resource.data.from;
    }

    // -----------------------------------------------------------------------
    // tipParticipation/{matchId} — hvem har tippet på kampen
    //   { uids: [...] } — vedligeholdes af Cloud Functions, afslører IKKE tips
    // -----------------------------------------------------------------------
    match /tipParticipation/{matchId} {
      // Alle godkendte brugere kan se hvor mange/hvem der har tippet
      allow read: if isApproved();

      // Kun server (Cloud Functions via admin-SDK) kan skrive
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // leagueActivity/{id} — aktivitets-feed pr. liga
    // -----------------------------------------------------------------------
    match /leagueActivity/{actId} {
      // Medlemmer (og admins) kan læse feedet
      allow read: if isMemberOfLeague(resource.data.leagueId) || isGlobalAdmin();

      // Opret: som sig selv, og enten medlem af ligaen eller admin
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.actorUid
        && (isMemberOfLeague(request.resource.data.leagueId) || isGlobalAdmin());

      // Ingen redigering
      allow update: if false;

      // Slet: ligaens ejer eller admin
      allow delete: if isGlobalAdmin()
        || (isSignedIn() && request.auth.uid ==
            get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.ownerUid);
    }

    // -----------------------------------------------------------------------
    // leagueBonus/{qid} — individuelle bonusspørgsmål pr. liga
    // -----------------------------------------------------------------------
    // Liga-"manager" = ligaens ejer, en udpeget liga-admin, eller global admin.
    function leagueDoc(leagueId) {
      return get(/databases/$(database)/documents/leagues/$(leagueId)).data;
    }
    function isLeagueManager(leagueId) {
      return isGlobalAdmin() || (isSignedIn() && (
        leagueDoc(leagueId).ownerUid == request.auth.uid
        || (request.auth.uid in leagueDoc(leagueId).get('adminUids', []))
      ));
    }

    match /leagueBonus/{qid} {
      // Medlemmer (og admins) kan læse ligaens bonusspørgsmål
      allow read: if isMemberOfLeague(resource.data.leagueId) || isGlobalAdmin();

      // Kun en liga-manager kan oprette/redigere/slette (inkl. sætte facit)
      allow create: if isApproved()
        && request.auth.uid == request.resource.data.createdBy
        && isLeagueManager(request.resource.data.leagueId);
      allow update: if isLeagueManager(resource.data.leagueId);
      allow delete: if isLeagueManager(resource.data.leagueId);
    }

    // -----------------------------------------------------------------------
    // leagueBonusAnswers/{id}  (id = qid_uid) — svar på liga-bonusspørgsmål
    // -----------------------------------------------------------------------
    match /leagueBonusAnswers/{ansId} {
      // Eget svar kan altid læses; manager/admin altid (følge deltagelse);
      // andres svar først EFTER spørgsmålets deadline.
      allow read: if isGlobalAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.uid)
        || isLeagueManager(resource.data.leagueId)
        || (isApproved()
            && request.time >= get(/databases/$(database)/documents/leagueBonus/$(resource.data.questionId)).data.deadline);

      // Opret/opdater eget svar, som medlem af ligaen, FØR deadline, uden points-felt
      allow create, update: if isApproved()
        && request.auth.uid == request.resource.data.uid
        && !request.resource.data.keys().hasAny(['points'])
        && isMemberOfLeague(request.resource.data.leagueId)
        && request.time < get(/databases/$(database)/documents/leagueBonus/$(request.resource.data.questionId)).data.deadline;

      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // config/{docId}
    // -----------------------------------------------------------------------
    match /config/{docId} {
      // Alle godkendte brugere kan læse konfiguration
      allow read: if isApproved();

      // Kun owner kan skrive konfiguration
      allow write: if isOwner();
    }
  }
}
