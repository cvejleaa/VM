# Firebase web-app konfiguration (offentlige værdier — IKKE hemmeligheder)
# Kopiér til .env og udfyld med værdier fra Firebase Console → Projektindstillinger
VITE_FIREBASE_API_KEY=din-api-key
VITE_FIREBASE_AUTH_DOMAIN=dit-projekt.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dit-projekt
VITE_FIREBASE_STORAGE_BUCKET=dit-projekt.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Sæt til "true" for at bruge lokale Firebase-emulatorer under udvikling
VITE_USE_EMULATORS=false

# Email på ejer/super-admin (bootstrappes som owner ved første login)
VITE_OWNER_EMAIL=cvejleaa@gmail.com

# App Check (valgfrit): reCAPTCHA v3-site-key fra Firebase Console → App Check.
# Når den er sat, beskyttes Firestore/Functions mod misbrug fra ikke-app-klienter.
# Lad den stå tom for at slå App Check fra (fx lokal udvikling).
VITE_RECAPTCHA_SITE_KEY=
# Valgfri debug-token til lokal kørsel uden rigtigt reCAPTCHA (fra browser-konsollen).
VITE_APPCHECK_DEBUG_TOKEN=
